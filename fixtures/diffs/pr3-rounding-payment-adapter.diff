-  return { status: "stubbed" };
+export async function authorizePayment(amountCents: number): Promise<{ status: "authorized"; amountCents: number }> {
+  if (!Number.isInteger(amountCents) || amountCents <= 0) {
+    throw new Error("amountCents must be a positive integer");
+  }
+
+  return { status: "authorized", amountCents };
 }
