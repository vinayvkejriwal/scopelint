@@ -1,3 +1,9 @@
 export function calculateAccrual(purchaseCents: number): number {
-  return purchaseCents / 100;
+  if (!Number.isInteger(purchaseCents) || purchaseCents <= 0) {
+    throw new Error("purchaseCents must be a positive integer");
+  }
+
+  const basePoints = Math.floor(purchaseCents / 100);
+  const highValuePurchaseBonus = purchaseCents >= 10_000 ? 100 : 0;
+  return basePoints + highValuePurchaseBonus;
 }
